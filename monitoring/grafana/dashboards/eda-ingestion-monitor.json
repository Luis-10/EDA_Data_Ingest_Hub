      },
      "targets": [
        {
          "expr": "sum(rate(http_response_size_bytes_sum{job=\"fastapi-backend\"}[5m])) by (handler) / clamp_min(sum(rate(http_response_size_bytes_count{job=\"fastapi-backend\"}[5m])) by (handler), 0.001)",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ]
