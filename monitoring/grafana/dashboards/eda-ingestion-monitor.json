{
  "uid": "eda-ingestion-monitor",
  "title": "EDA Data Ingest Hub - Monitor",
  "description": "Monitoreo en tiempo real de la ingesta de datos: API requests, ETL pipeline, latencia y errores.",
  "tags": ["eda", "ingestion", "fastapi", "etl"],
  "timezone": "browser",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "refresh": "10s",
  "schemaVersion": 39,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m"],
    "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "7d"]
  },
  "templating": {
    "list": [
      {
        "name": "method",
        "type": "custom",
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "options": [
          { "selected": true, "text": "All", "value": "$__all" },
          { "selected": false, "text": "GET", "value": "GET" },
          { "selected": false, "text": "POST", "value": "POST" },
          { "selected": false, "text": "DELETE", "value": "DELETE" }
        ],
        "includeAll": true,
        "multi": true,
        "label": "HTTP Method"
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "title": "OVERVIEW",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "id": 1,
      "title": "Requests Totales",
      "description": "Total acumulado de requests HTTP al backend",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#FF9830", "value": 10000 },
              { "color": "#F2495C", "value": 50000 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(http_requests_total{job=\"fastapi-backend\"})",
          "legendFormat": "Total",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Request Rate (req/s)",
      "description": "Requests por segundo (promedio 1 min)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#FADE2A", "value": 50 },
              { "color": "#F2495C", "value": 100 }
            ]
          },
          "unit": "reqps",
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"fastapi-backend\"}[1m]))",
          "legendFormat": "req/s",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Error Rate (%)",
      "description": "Porcentaje de respuestas 4xx + 5xx en el ultimo minuto",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#FADE2A", "value": 5 },
              { "color": "#FF9830", "value": 15 },
              { "color": "#F2495C", "value": 30 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 1
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "100 * sum(rate(http_requests_total{job=\"fastapi-backend\", status=~\"4xx|5xx\"}[1m])) / clamp_min(sum(rate(http_requests_total{job=\"fastapi-backend\"}[1m])), 0.001)",
          "legendFormat": "Error %",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Latencia P50 / P95 / P99",
      "description": "Percentiles de latencia globales",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#FADE2A", "value": 1 },
              { "color": "#F2495C", "value": 5 }
            ]
          },
          "unit": "s",
          "decimals": 3
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"fastapi-backend\"}[5m])) by (le))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"fastapi-backend\"}[5m])) by (le))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"fastapi-backend\"}[5m])) by (le))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ]
    },
    {
      "id": 5,
      "title": "Requests In-Progress",
      "description": "Requests actualmente en proceso",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#73BF69", "value": null },
              { "color": "#FADE2A", "value": 20 },
              { "color": "#F2495C", "value": 50 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "targets": [
        {
          "expr": "sum(http_requests_in_progress{job=\"fastapi-backend\"})",
          "legendFormat": "In-Progress",
          "refId": "A"
        }
      ]
    },
    {
      "id": 200,
      "title": "ETL PIPELINE - INGESTA",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false
    },
    {
      "id": 10,
      "title": "ETL Requests por Tipo (rate/min)",
      "description": "Tasa de requests ETL separados por tipo de medio (TV, Radio, Impresos)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisLabel": "requests/min",
            "drawStyle": "bars",
            "fillOpacity": 60,
            "gradientMode": "scheme",
            "lineWidth": 1,
            "pointSize": 5,
            "showPoints": "auto",
            "stacking": { "group": "A", "mode": "normal" },
            "barAlignment": 0
          },
          "unit": "short",
          "decimals": 0
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "TV ETL" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#6ED0E0", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Radio ETL" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#EF843C", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Impresos ETL" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#E24D42", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["sum"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "increase(http_requests_total{job=\"fastapi-backend\", handler=~\"/api/tv/etl.*\", method=\"POST\"}[1m])",
          "legendFormat": "TV ETL",
          "refId": "A"
        },
        {
          "expr": "increase(http_requests_total{job=\"fastapi-backend\", handler=~\"/api/radio/etl.*\", method=\"POST\"}[1m])",
          "legendFormat": "Radio ETL",
          "refId": "B"
        },
        {
          "expr": "increase(http_requests_total{job=\"fastapi-backend\", handler=~\"/api/impresos/etl.*\", method=\"POST\"}[1m])",
          "legendFormat": "Impresos ETL",
          "refId": "C"
        }
      ]
    },
    {
      "id": 11,
      "title": "ETL Latencia por Tipo (P95)",
      "description": "Percentil 95 de duracion de requests ETL por tipo de medio",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "axisBorderShow": false,
            "axisLabel": "segundos",
            "drawStyle": "line",
            "fillOpacity": 15,
            "gradientMode": "scheme",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": true
          },
          "unit": "s",
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"fastapi-backend\", handler=~\"/api/tv/etl.*\"}[5m])) by (le))",
          "legendFormat": "TV P95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"fastapi-backend\", handler=~\"/api/radio/etl.*\"}[5m])) by (le))",
          "legendFormat": "Radio P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"fastapi-backend\", handler=~\"/api/impresos/etl.*\"}[5m])) by (le))",
          "legendFormat": "Impresos P95",
          "refId": "C"
        }
      ]
    },
    {
      "id": 12,
      "title": "ETL Exitosos vs Fallidos",
      "description": "Requests ETL agrupados por codigo de status HTTP",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 70,
            "stacking": { "group": "A", "mode": "normal" },
            "lineWidth": 1
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "2xx Exitosos" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#73BF69", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "4xx Rechazados" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#FADE2A", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "5xx Errores" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["sum"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum(increase(http_requests_total{job=\"fastapi-backend\", handler=~\"/api/(tv|radio|impresos)/etl.*\", method=\"POST\", status=\"2xx\"}[1m]))",
          "legendFormat": "2xx Exitosos",
          "refId": "A"
        },
        {
          "expr": "sum(increase(http_requests_total{job=\"fastapi-backend\", handler=~\"/api/(tv|radio|impresos)/etl.*\", method=\"POST\", status=\"4xx\"}[1m]))",
          "legendFormat": "4xx Rechazados",
          "refId": "B"
        },
        {
          "expr": "sum(increase(http_requests_total{job=\"fastapi-backend\", handler=~\"/api/(tv|radio|impresos)/etl.*\", method=\"POST\", status=\"5xx\"}[1m]))",
          "legendFormat": "5xx Errores",
          "refId": "C"
        }
      ]
    },
    {
      "id": 13,
      "title": "DELETE Operations (rate/min)",
      "description": "Tasa de operaciones de eliminacion de datos",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 50,
            "lineWidth": 1,
            "stacking": { "group": "A", "mode": "normal" }
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "TV DELETE" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#F2495C", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Radio DELETE" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#FF9830", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Impresos DELETE" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#FADE2A", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["sum"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "increase(http_requests_total{job=\"fastapi-backend\", handler=~\"/api/tv/.*\", method=\"DELETE\"}[1m])",
          "legendFormat": "TV DELETE",
          "refId": "A"
        },
        {
          "expr": "increase(http_requests_total{job=\"fastapi-backend\", handler=~\"/api/radio/.*\", method=\"DELETE\"}[1m])",
          "legendFormat": "Radio DELETE",
          "refId": "B"
        },
        {
          "expr": "increase(http_requests_total{job=\"fastapi-backend\", handler=~\"/api/impresos/.*\", method=\"DELETE\"}[1m])",
          "legendFormat": "Impresos DELETE",
          "refId": "C"
        }
      ]
    },
    {
      "id": 14,
      "title": "ETL Acumulado por Tipo (hoy)",
      "description": "Total de requests ETL exitosos acumulados en el rango visible",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "TV" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#6ED0E0", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Radio" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#EF843C", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Impresos" },
            "properties": [{ "id": "color", "value": { "fixedColor": "#E24D42", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "pieType": "donut",
        "tooltip": { "mode": "single", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "right", "values": ["value", "percent"] }
      },
      "targets": [
        {
          "expr": "sum(increase(http_requests_total{job=\"fastapi-backend\", handler=~\"/api/tv/etl.*\", method=\"POST\", status=\"2xx\"}[$__range]))",
          "legendFormat": "TV",
          "refId": "A"
        },
        {
          "expr": "sum(increase(http_requests_total{job=\"fastapi-backend\", handler=~\"/api/radio/etl.*\", method=\"POST\", status=\"2xx\"}[$__range]))",
          "legendFormat": "Radio",
          "refId": "B"
        },
        {
          "expr": "sum(increase(http_requests_total{job=\"fastapi-backend\", handler=~\"/api/impresos/etl.*\", method=\"POST\", status=\"2xx\"}[$__range]))",
          "legendFormat": "Impresos",
          "refId": "C"
        }
      ]
    },
    {
      "id": 300,
      "title": "LATENCIA Y RENDIMIENTO",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "collapsed": false
    },
    {
      "id": 20,
      "title": "Latencia por Endpoint (P95)",
      "description": "Percentil 95 de duracion por handler - identifica endpoints lentos",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": true
          },
          "unit": "s",
          "decimals": 3
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max", "lastNotNull"], "sortBy": "Max", "sortDesc": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"fastapi-backend\"}[5m])) by (le, handler))",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 21,
      "title": "Distribucion de Latencia (Heatmap)",
      "description": "Distribucion de tiempos de respuesta — identifica bimodalidad",
      "type": "heatmap",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": {
        "calculate": false,
        "yAxis": { "unit": "s" },
        "color": {
          "mode": "scheme",
          "scheme": "Oranges",
          "steps": 128
        },
        "cellGap": 1,
        "tooltip": { "show": true, "yHistogram": true },
        "exemplars": { "color": "rgba(255,0,255,0.7)" }
      },
      "targets": [
        {
          "expr": "sum(increase(http_request_duration_seconds_bucket{job=\"fastapi-backend\"}[1m])) by (le)",
          "legendFormat": "{{le}}",
          "refId": "A",
          "format": "heatmap"
        }
      ]
    },
    {
      "id": 22,
      "title": "Request Rate por Endpoint",
      "description": "Top endpoints por volumen de requests",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 31 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 1,
            "stacking": { "group": "A", "mode": "normal" }
          },
          "unit": "reqps",
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "sum"], "sortBy": "Total", "sortDesc": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"fastapi-backend\", method=~\"$method\"}[1m])) by (handler)",
          "legendFormat": "{{handler}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 23,
      "title": "Response Size (bytes) por Endpoint",
      "description": "Tamano promedio de respuestas — detecta payloads anormalmente grandes",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 31 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "spanNulls": true
          },
          "unit": "decbytes",
          "decimals": 0
        },
        "overrides": []
